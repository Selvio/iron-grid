    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "game-data": "workspace:*",
    "game-engine": "workspace:*",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "phaser": "^4.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "resend": "^6.17.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
