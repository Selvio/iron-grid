    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky",
    "atlas": "tsx scripts/build-atlas.ts",
    "map-thumbs": "tsx scripts/build-map-thumbnails.ts",
    "seed:match": "tsx --env-file=.env scripts/seed-practice-match.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@hookform/resolvers": "^5.4.0",
    "@neondatabase/serverless": "^1.1.0",
